{
  "name": "fractal-lab",
  "type": "module",
  "version": "1.0.0",
  "description": "Realtime fractal art playground powered by Astro and Three.js.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "deploy": "bun run build && bunx wrangler pages deploy dist --project-name fractal-lab",
    "lint": "oxlint",
    "format": "oxfmt",
    "prepare": "husky"
  },
  "dependencies": {
    "astro": "^6.0.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/cloudflare": "^12.6.13",
    "typescript": "^5.9.3",
    "oxlint": "^1.52.0",
    "oxfmt": "^0.37.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  }
}
